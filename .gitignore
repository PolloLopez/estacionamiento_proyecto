# Archivo .gitignore
# Define los archivos y carpetas que no deben subirse al repositorio Git
# ============================
# 📌 ENTORNO VIRTUAL
# ============================
.venv/
venv/
env/
ENV/

# ============================
# 📌 ARCHIVOS DE PYTHON
# ============================
__pycache__/
*.py[cod]
*$py.class

# ============================
# 📌 ARCHIVOS SENSIBLES
# ============================
.env
*.env
.env.*
# El ejemplo sí se commitea — es documentación de variables requeridas
!.env.example

# ============================
# 📌 DJANGO
# ============================
db.sqlite3
media/
staticfiles/

# ============================
# 📌 ARCHIVOS DEL SISTEMA
# ============================
*.log
*.pot
*.pyc
*.pyo
*.mo
*.swp
.DS_Store
Thumbs.db

# ============================
# 📌 ENTORNOS / CACHE / IDE
# ============================
.idea/
.vscode/
*.sqlite3-journal
*.tmp

# ============================
# 📌 DISTRIBUCIÓN / COMPILACIÓN
# ============================
build/
dist/
*.egg-info/
