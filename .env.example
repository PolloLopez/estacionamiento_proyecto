# ─── Copiar este archivo a .env y completar los valores ──────────────────────
# El archivo .env NO se commitea (está en .gitignore).
# En Railway/Render se configuran como variables de entorno en el panel web.

# ─── Django ───────────────────────────────────────────────────────────────────
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambiar-por-una-clave-secreta-real

# False en producción, True en desarrollo local
DEBUG=True

# Dominio de Railway: tuapp.up.railway.app
# En local dejar vacío (usará "*")
ALLOWED_HOSTS=

# ─── Base de datos ────────────────────────────────────────────────────────────
# Railway/Render lo inyectan automáticamente.
# En local: dejar vacío para usar SQLite.
DATABASE_URL=

# ─── CSRF ─────────────────────────────────────────────────────────────────────
# En Railway: https://tuapp.up.railway.app
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ─── MercadoPago (próximamente) ───────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
